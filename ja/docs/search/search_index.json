\u516c\u5f0f <code>terms.html</code> \u306e\u9593\u3067\u9f5f\u9f6c\u304c\u3042\u308b\u5834\u5408\u306f <code>terms.html</code> \u304c\u512a\u5148\u3057\u307e\u3059\u3002</p>"},{"location":"legal/eula/","title":"\u30a8\u30f3\u30c9\u30e6\u30fc\u30b6\u30fc\u30e9\u30a4\u30bb\u30f3\u30b9\u5951\u7d04\uff08EULA\uff09\u2014 \u8981\u65e8","text":"<p>\u6cd5\u7684\u62d8\u675f\u529b\u306b\u3064\u3044\u3066</p> <p>\u672c EULA \u306f \u82f1\u8a9e\u7248\uff08<code>EULA.md</code>\uff09\u304c\u6cd5\u7684\u62d8\u675f\u529b\u3092\u6301\u3064\u6b63\u672c \u3067\u3059\u3002\u672c\u30da\u30fc\u30b8\u306b\u63b2\u8f09\u3059\u308b\u65e5\u672c\u8a9e\u306e\u8981\u65e8\u306f\u8aad\u8005\u306e\u7406\u89e3\u3092\u52a9\u3051\u308b\u305f\u3081\u306e \u53c2\u8003\u8a33 \u3067\u3042\u308a\u3001\u82f1\u8a9e\u539f\u6587\u3068\u306e\u9593\u3067\u9f5f\u9f6c\u304c\u3042\u308b\u5834\u5408\u306f\u82f1\u8a9e\u539f\u6587\u306e\u89e3\u91c8\u304c\u512a\u5148\u3057\u307e\u3059\u3002</p> <p>Effective Date: 2026-04-29 / Version: 1.0</p> <p>AlphaForge \u3092\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u3001\u30b3\u30d4\u30fc\u3001\u30a2\u30af\u30bb\u30b9\u3001\u307e\u305f\u306f\u4f7f\u7528\u3059\u308b\u3053\u3068\u306b\u3088\u3063\u3066\u3001\u672c\u5951\u7d04\u306e\u6761\u9805\u3092\u8aad\u307f\u3001\u7406\u89e3\u3057\u3001\u3053\u308c\u306b\u62d8\u675f\u3055\u308c\u308b\u3053\u3068\u306b\u540c\u610f\u3057\u305f\u3082\u306e\u3068\u307f\u306a\u3055\u308c\u307e\u3059\u3002</p>"},{"location":"legal/eula/#1","title":"1. \u30e9\u30a4\u30bb\u30f3\u30b9\u306e\u4ed8\u4e0e","text":"<p>Alforge Labs\uff08\u4ee5\u4e0b\u300c\u30e9\u30a4\u30bb\u30f3\u30b5\u30fc\u300d\uff09\u306f\u3001\u672c\u5951\u7d04\u306e\u7d99\u7d9a\u7684\u9075\u5b88\u3068\u9069\u7528\u3055\u308c\u308b\u6599\u91d1\u306e\u652f\u6255\u3044\u3092\u6761\u4ef6\u3068\u3057\u3066\u3001\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u306b\u5bfe\u3057\u3001\u9650\u5b9a\u7684\u30fb\u975e\u72ec\u5360\u7684\u30fb\u8b72\u6e21\u4e0d\u80fd\u30fb\u30b5\u30d6\u30e9\u30a4\u30bb\u30f3\u30b9\u4e0d\u80fd\u30fb\u53d6\u6d88\u53ef\u80fd\u306a\u30e9\u30a4\u30bb\u30f3\u30b9\u3092\u4ed8\u4e0e\u3057\u307e\u3059\u3002\u672c\u30e9\u30a4\u30bb\u30f3\u30b9\u306f\u3001\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u81ea\u8eab\u306e\u793e\u5185\u7814\u7a76\u30fb\u958b\u767a\u30fb\u500b\u4eba\u53d6\u5f15\u30ef\u30fc\u30af\u30d5\u30ed\u30fc\u306b\u9650\u5b9a\u3057\u3066\u3001\u30aa\u30d6\u30b8\u30a7\u30af\u30c8\u30b3\u30fc\u30c9\u5f62\u5f0f\u306e\u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u3092\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u30fb\u4f7f\u7528\u3059\u308b\u6a29\u5229\u306e\u307f\u3092\u8a8d\u3081\u308b\u3082\u306e\u3067\u3059\u3002</p> <p>\u30e9\u30a4\u30bb\u30f3\u30b9\u306f\u8a8d\u8a3c\u30e6\u30fc\u30b6\u30fc\u5358\u4f4d\u3067\u4ed8\u4e0e\u3055\u308c\u3001\u5225\u9014\u66f8\u9762\u306e\u5408\u610f\u306a\u3057\u306b\u3001\u8907\u6570\u30e6\u30fc\u30b6\u30fc\u5229\u7528\u3001\u30db\u30b9\u30c6\u30a3\u30f3\u30b0\u3001\u30b5\u30fc\u30d3\u30b9\u30d3\u30e5\u30fc\u30ed\u30fc\u3001\u30bf\u30a4\u30e0\u30b7\u30a7\u30a2\u30ea\u30f3\u30b0\u306f\u8a8d\u3081\u3089\u308c\u307e\u305b\u3093\u3002</p>"},{"location":"legal/eula/#2","title":"2. \u7981\u6b62\u4e8b\u9805","text":"<p>\u4ee5\u4e0b\u306e\u884c\u70ba\u306f\u3001\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u307e\u305f\u306f\u7b2c\u4e09\u8005\u3092\u901a\u3058\u3066\u3001\u76f4\u63a5\u9593\u63a5\u3092\u554f\u308f\u305a\u7981\u6b62\u3055\u308c\u307e\u3059\u3002</p> <ul> <li>\u30ea\u30d0\u30fc\u30b9\u30a8\u30f3\u30b8\u30cb\u30a2\u30ea\u30f3\u30b0\u306e\u7981\u6b62: \u9759\u7684\u89e3\u6790\u30fb\u52d5\u7684\u8a08\u88c5\u30fb\u30c7\u30d0\u30c3\u30b0\u30fb\u30e1\u30e2\u30ea\u691c\u67fb\u30fb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u691c\u67fb\u30fbAI \u3092\u4f7f\u3063\u305f\u518d\u69cb\u6210\u3092\u542b\u3080\u3001\u3044\u304b\u306a\u308b\u624b\u6bb5\u306b\u3088\u308b\u30bd\u30fc\u30b9\u30b3\u30fc\u30c9\u30fb\u5185\u90e8\u30a2\u30eb\u30b4\u30ea\u30ba\u30e0\u30fb\u975e\u516c\u958b API \u306e\u89e3\u6790\u3002</li> <li>\u30d0\u30a4\u30ca\u30ea\u6539\u5909\u306e\u7981\u6b62: \u30d0\u30a4\u30ca\u30ea\u3001\u30e9\u30a4\u30bb\u30f3\u30b9\u691c\u8a3c\u6a5f\u69cb\u3001\u30c6\u30ec\u30e1\u30c8\u30ea\u3001\u8a8d\u8a3c\u30eb\u30fc\u30c1\u30f3\u306e\u6539\u5909\u3001\u7ffb\u6848\u3001\u30d1\u30c3\u30c1\u3002</li> <li>\u518d\u914d\u5e03\u306e\u7981\u6b62: \u8ca9\u58f2\u3001\u8ee2\u58f2\u3001\u8cc3\u8cb8\u3001\u30ea\u30fc\u30b9\u3001\u8cb8\u4e0e\u3001\u30b5\u30d6\u30e9\u30a4\u30bb\u30f3\u30b9\u3001\u914d\u5e03\u3001\u516c\u958b\u3001\u4f1d\u9001\u3001\u30db\u30b9\u30c8\u3001\u305d\u306e\u4ed6\u7b2c\u4e09\u8005\u3078\u306e\u63d0\u4f9b\u3002</li> <li>\u56de\u907f\u884c\u70ba\u306e\u7981\u6b62: \u30e9\u30a4\u30bb\u30f3\u30b9\u691c\u8a3c\u3001\u8a8d\u8a3c\u3001\u30d5\u30a3\u30f3\u30ac\u30fc\u30d7\u30ea\u30f3\u30c6\u30a3\u30f3\u30b0\u3001\u5229\u7528\u8ffd\u8de1\u3001\u30b3\u30d4\u30fc\u4fdd\u8b77\u6a5f\u80fd\u306e\u56de\u907f\u30fb\u7121\u52b9\u5316\u30fb\u6539\u7ac4\u3002</li> <li>\u901a\u77e5\u524a\u9664\u306e\u7981\u6b62: \u8457\u4f5c\u6a29\u30fb\u5546\u6a19\u30fb\u30e9\u30a4\u30bb\u30f3\u30b9\u30fb\u5e30\u5c5e\u8868\u793a\u306e\u524a\u9664\u3001\u6539\u5909\u3001\u4e0d\u63b2\u8f09\u3002</li> <li>\u7af6\u5408\u5229\u7528\u306e\u7981\u6b62: \u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u3001\u305d\u306e\u51fa\u529b\u3001\u307e\u305f\u306f\u5229\u7528\u3092\u901a\u3058\u3066\u89b3\u5bdf\u3057\u305f\u60c5\u5831\u3092\u3001\u7af6\u5408\u88fd\u54c1\u306e\u958b\u767a\u30fb\u8a13\u7df4\u30fb\u6539\u5584\u306b\u7528\u3044\u308b\u3053\u3068\u3002</li> <li>\u9055\u6cd5\u5229\u7528\u306e\u7981\u6b62: \u9069\u7528\u6cd5\u4ee4\u3001\u898f\u5236\u3001\u7b2c\u4e09\u8005\u306e\u6a29\u5229\uff08\u8a3c\u5238\u6cd5\u3001\u53d6\u5f15\u6240\u898f\u5247\u3001\u5e02\u5834\u6feb\u7528\u898f\u5236\u3092\u542b\u3080\uff09\u306b\u9055\u53cd\u3059\u308b\u5229\u7528\u3002</li> </ul>"},{"location":"legal/eula/#3","title":"3. \u77e5\u7684\u8ca1\u7523","text":"<p>\u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u306f\u30e9\u30a4\u30bb\u30f3\u30b9\u3055\u308c\u308b\u3082\u306e\u3067\u3042\u308a\u3001\u8ca9\u58f2\u3055\u308c\u308b\u3082\u306e\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u3059\u3079\u3066\u306e\u77e5\u7684\u8ca1\u7523\u6a29\u306f\u30e9\u30a4\u30bb\u30f3\u30b5\u30fc\u304a\u3088\u3073\u305d\u306e\u30b5\u30d7\u30e9\u30a4\u30e4\u30fc\u306b\u5e30\u5c5e\u3057\u307e\u3059\u3002\u672c\u5951\u7d04\u3067\u660e\u793a\u7684\u306b\u4ed8\u4e0e\u3055\u308c\u305f\u6a29\u5229\u4ee5\u5916\u306e\u6a29\u5229\u306f\u3001\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u306b\u4ed8\u4e0e\u3055\u308c\u307e\u305b\u3093\u3002</p>"},{"location":"legal/eula/#4","title":"4. \u91d1\u878d\u7684\u8cac\u4efb\u306e\u514d\u8cac\uff08\u91cd\u8981\uff09","text":"<p>\u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u306f\u6226\u7565\u7814\u7a76\u30fb\u30d0\u30c3\u30af\u30c6\u30b9\u30c8\u306e\u305f\u3081\u306e \u6280\u8853\u30c4\u30fc\u30eb \u3067\u3042\u308a\u3001\u91d1\u878d\u3001\u6295\u8cc7\u3001\u4f1a\u8a08\u3001\u6cd5\u5f8b\u3001\u7a0e\u52d9\u3001\u898f\u5236\u4e0a\u306e\u52a9\u8a00\u3067\u306f\u306a\u304f\u3001\u307e\u305f\u52a9\u8a00\u3068\u3057\u3066\u6271\u308f\u308c\u3066\u306f\u306a\u308a\u307e\u305b\u3093\u3002</p> <ul> <li>\u52a9\u8a00\u95a2\u4fc2\u306e\u4e0d\u5728: \u30e9\u30a4\u30bb\u30f3\u30b5\u30fc\u306f\u767b\u9332\u6295\u8cc7\u9867\u554f\u3001\u30d6\u30ed\u30fc\u30ab\u30fc\u30c7\u30a3\u30fc\u30e9\u30fc\u3001\u5546\u54c1\u53d6\u5f15\u9867\u554f\u3001\u307e\u305f\u306f\u53d7\u8a17\u8005\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002</li> <li>\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9\u306e\u975e\u4fdd\u8a3c: \u30d0\u30c3\u30af\u30c6\u30b9\u30c8\u7d50\u679c\u3001\u6700\u9069\u5316\u51fa\u529b\u3001\u30b7\u30df\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3\u6307\u6a19\u306f\u8aac\u660e\u76ee\u7684\u306b\u3059\u304e\u307e\u305b\u3093\u3002\u904e\u53bb\u307e\u305f\u306f\u6a21\u64ec\u306e\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9\u306f\u5c06\u6765\u306e\u7d50\u679c\u3092\u793a\u3057\u307e\u305b\u3093\u3002</li> <li>\u53d6\u5f15\u5224\u65ad\u306e\u81ea\u5df1\u8cac\u4efb: \u6226\u7565\u9078\u629e\u3001\u30d1\u30e9\u30e1\u30fc\u30bf\u3001\u9298\u67c4\u3001\u30dd\u30b8\u30b7\u30e7\u30f3\u30b5\u30a4\u30ba\u3001\u57f7\u884c\u4f1a\u5834\u306e\u9078\u629e\u3092\u542b\u3080\u3059\u3079\u3066\u306e\u53d6\u5f15\u30fb\u6295\u8cc7\u5224\u65ad\u306f\u3001\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u306e\u5358\u72ec\u88c1\u91cf\u3068\u5358\u72ec\u30ea\u30b9\u30af\u3067\u884c\u308f\u308c\u307e\u3059\u3002</li> <li>\u6295\u8cc7\u640d\u5931\u306e\u514d\u8cac: \u30e9\u30a4\u30bb\u30f3\u30b5\u30fc\u306f\u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u306e\u4f7f\u7528\u306b\u8d77\u56e0\u3059\u308b\u53d6\u5f15\u640d\u5931\u3001\u6a5f\u4f1a\u640d\u5931\u3001\u8ffd\u8a3c\u3001\u5f37\u5236\u6c7a\u6e08\u3001\u7a0e\u52d9\u4e0a\u306e\u5f71\u97ff\u3001\u305d\u306e\u4ed6\u306e\u91d1\u92ad\u7684\u640d\u5bb3\u306b\u3064\u3044\u3066\u4e00\u5207\u306e\u8cac\u4efb\u3092\u8ca0\u3044\u307e\u305b\u3093\u3002</li> </ul>"},{"location":"legal/eula/#5","title":"5. \u4fdd\u8a3c\u306e\u5426\u8a8d","text":"<p>\u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u306f \u300c\u73fe\u72b6\u306e\u307e\u307e\u300d\u300c\u5229\u7528\u53ef\u80fd\u306a\u7bc4\u56f2\u3067\u300d\u3001\u3044\u304b\u306a\u308b\u7a2e\u985e\u306e\u4fdd\u8a3c\u3082\u306a\u304f\u63d0\u4f9b\u3055\u308c\u307e\u3059\u3002\u5546\u54c1\u6027\u3001\u7279\u5b9a\u76ee\u7684\u3078\u306e\u9069\u5408\u6027\u3001\u6240\u6709\u6a29\u3001\u975e\u4fb5\u5bb3\u6027\u3001\u6b63\u78ba\u6027\u3001\u4fe1\u983c\u6027\u3001\u5b8c\u5168\u6027\u3001\u53ef\u7528\u6027\u3001\u5e73\u7a4f\u306a\u5229\u7528\u306b\u95a2\u3059\u308b\u4fdd\u8a3c\u3092\u542b\u3080\u3001\u660e\u793a\u307e\u305f\u306f\u9ed9\u793a\u306e\u3059\u3079\u3066\u306e\u4fdd\u8a3c\u3092\u5426\u8a8d\u3057\u307e\u3059\u3002</p>"},{"location":"legal/eula/#6","title":"6. \u8cac\u4efb\u306e\u5236\u9650","text":"<p>\u30e9\u30a4\u30bb\u30f3\u30b5\u30fc\u306e\u8cac\u4efb\u7dcf\u984d\u306f\u3001(a) \u8acb\u6c42\u306e\u767a\u751f\u4e8b\u8c61\u306b\u5148\u7acb\u3064 12 \u30f6\u6708\u9593\u306b\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u304c\u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u306b\u5bfe\u3057\u3066\u5b9f\u969b\u306b\u652f\u6255\u3063\u305f\u6599\u91d1\u3001\u307e\u305f\u306f (b) 100 \u7c73\u30c9\u30eb\u306e\u3044\u305a\u308c\u304b\u5927\u304d\u3044\u65b9\u3092\u4e0a\u9650\u3068\u3057\u307e\u3059\u3002\u9593\u63a5\u7684\u3001\u4ed8\u968f\u7684\u3001\u7279\u5225\u3001\u7d50\u679c\u7684\u3001\u6a21\u7bc4\u7684\u3001\u61f2\u7f70\u7684\u640d\u5bb3\u306b\u3064\u3044\u3066\u306f\u4e00\u5207\u8cac\u4efb\u3092\u8ca0\u3044\u307e\u305b\u3093\u3002</p>"},{"location":"legal/eula/#7","title":"7. \u671f\u9593\u3068\u7d42\u4e86","text":"<p>\u672c\u5951\u7d04\u306f\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u306e\u53d7\u8afe\u6642\u306b\u767a\u52b9\u3057\u3001\u7d42\u4e86\u307e\u3067\u7d99\u7d9a\u3057\u307e\u3059\u3002\u672c\u5951\u7d04\u306b\u9055\u53cd\u3057\u305f\u5834\u5408\u3001\u30e9\u30a4\u30bb\u30f3\u30b5\u30fc\u306f\u5373\u6642\u306b\u672c\u5951\u7d04\u3092\u7d42\u4e86\u307e\u305f\u306f\u505c\u6b62\u3067\u304d\u307e\u3059\u3002\u7d42\u4e86\u6642\u3001\u30e9\u30a4\u30bb\u30f3\u30b7\u30fc\u306f\u3059\u3079\u3066\u306e\u672c\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u306e\u30b3\u30d4\u30fc\u3092\u901f\u3084\u304b\u306b\u30a2\u30f3\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u30fb\u7834\u68c4\u3057\u306a\u3051\u308c\u3070\u306a\u308a\u307e\u305b\u3093\u3002</p>"},{"location":"legal/eula/#8","title":"8. \u6e96\u62e0\u6cd5\u3068\u7d1b\u4e89\u89e3\u6c7a","text":"<p>\u672c\u5951\u7d04\u306f \u65e5\u672c\u6cd5 \u306b\u6e96\u62e0\u3057\u3001\u6771\u4eac\u306e\u88c1\u5224\u6240\u3092\u5c02\u5c5e\u7684\u5408\u610f\u7ba1\u8f44\u3068\u3057\u307e\u3059\u3002</p>"},{"location":"legal/eula/#_1","title":"\u5b8c\u5168\u306a\u539f\u6587","text":"<p>\u6cd5\u7684\u306b\u62d8\u675f\u529b\u3092\u6301\u3064\u5b8c\u5168\u306a\u6761\u9805\u306b\u3064\u3044\u3066\u306f\u3001\u4ee5\u4e0b\u306e\u82f1\u8a9e\u539f\u6587\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p> <p>EULA.md\uff08\u82f1\u8a9e\u539f\u6587\u30fb\u6b63\u672c\uff09\u2192</p> <p>\u540c\u671f\u5143: \u30ea\u30dd\u30b8\u30c8\u30ea\u306e <code>EULA.md</code>\uff08Version 1.0\u3001Effective Date: 2026-04-29\uff09\u3002\u672c\u30da\u30fc\u30b8\u306e\u65e5\u672c\u8a9e\u8981\u65e8\u3068\u82f1\u8a9e\u539f\u6587\u306e\u9593\u3067\u9f5f\u9f6c\u304c\u3042\u308b\u5834\u5408\u306f\u82f1\u8a9e\u539f\u6587\u304c\u512a\u5148\u3057\u307e\u3059\u3002</p>"},{"location":"legal/privacy/","title":"\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u30dd\u30ea\u30b7\u30fc","text":"<p>\u6700\u7d42\u66f4\u65b0\u65e5: 2026 \u5e74 4 \u6708 25 \u65e5</p> <p>Alforge Labs\uff08\u4ee5\u4e0b\u300c\u5f53\u793e\u300d\uff09\u306f\u3001AlphaForge CLI \u306e\u63d0\u4f9b\u306b\u3042\u305f\u308a\u53ce\u96c6\u3059\u308b\u500b\u4eba\u60c5\u5831\u306e\u53d6\u308a\u6271\u3044\u306b\u3064\u3044\u3066\u3001\u4ee5\u4e0b\u306e\u901a\u308a\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u30dd\u30ea\u30b7\u30fc\u3092\u5b9a\u3081\u307e\u3059\u3002</p>"},{"location":"legal/privacy/#1","title":"1. \u53ce\u96c6\u3059\u308b\u60c5\u5831","text":""},{"location":"legal/privacy/#11","title":"1.1 \u8cfc\u5165\u6642\u306b\u53ce\u96c6\u3059\u308b\u60c5\u5831","text":"<p>LemonSqueezy \u3092\u901a\u3058\u305f\u30e9\u30a4\u30bb\u30f3\u30b9\u8cfc\u5165\u6642\u306b\u3001\u6c0f\u540d\u307e\u305f\u306f\u4f1a\u793e\u540d\u3001\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3001\u6c7a\u6e08\u60c5\u5831\u3001\u56fd\u30fb\u5730\u57df\u60c5\u5831\u304c\u53ce\u96c6\u3055\u308c\u307e\u3059\u3002\u6c7a\u6e08\u60c5\u5831\u306f LemonSqueezy \u304c\u51e6\u7406\u3057\u3001\u5f53\u793e\u306f\u4fdd\u6301\u3057\u307e\u305b\u3093\u3002</p>"},{"location":"legal/privacy/#12","title":"1.2 \u30e9\u30a4\u30bb\u30f3\u30b9\u8a8d\u8a3c\u6642\u306b\u53ce\u96c6\u3059\u308b\u60c5\u5831","text":"<p><code>forge license activate</code> \u5b9f\u884c\u6642\u306b\u3001\u30e9\u30a4\u30bb\u30f3\u30b9\u30ad\u30fc\u3001\u30a4\u30f3\u30b9\u30bf\u30f3\u30b9\u540d\u3001\u30a2\u30af\u30c6\u30a3\u30d9\u30fc\u30b7\u30e7\u30f3\u65e5\u6642\u304c LemonSqueezy \u306e License API \u306b\u9001\u4fe1\u3055\u308c\u307e\u3059\u3002</p>"},{"location":"legal/privacy/#13","title":"1.3 \u53ce\u96c6\u3057\u306a\u3044\u60c5\u5831","text":"<p>\u30ed\u30fc\u30ab\u30eb\u5b8c\u7d50\u578b\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2</p> <p>AlphaForge CLI \u306f\u30ed\u30fc\u30ab\u30eb\u5b8c\u7d50\u578b\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u3067\u3059\u3002\u30d0\u30c3\u30af\u30c6\u30b9\u30c8\u8a2d\u5b9a\u3001\u6700\u9069\u5316\u30d1\u30e9\u30e1\u30fc\u30bf\u3001\u6226\u7565\u30c7\u30fc\u30bf\u3001\u53d6\u5f15\u5c65\u6b74\u3001\u30dd\u30b8\u30b7\u30e7\u30f3\u60c5\u5831\u3001\u30ed\u30fc\u30ab\u30eb\u30d5\u30a1\u30a4\u30eb\u3001\u64cd\u4f5c\u30ed\u30b0\u306f\u5f53\u793e\u30b5\u30fc\u30d0\u30fc\u3078\u9001\u4fe1\u3055\u308c\u307e\u305b\u3093\u3002</p>"},{"location":"legal/privacy/#2","title":"2. \u60c5\u5831\u306e\u5229\u7528\u76ee\u7684","text":"<ul> <li>\u30e9\u30a4\u30bb\u30f3\u30b9\u30ad\u30fc\u306e\u767a\u884c\u30fb\u8a8d\u8a3c\u30fb\u7ba1\u7406</li> <li>\u8cfc\u5165\u78ba\u8a8d\u30e1\u30fc\u30eb\u30fb\u9818\u53ce\u66f8\u306e\u9001\u4ed8</li> <li>\u88fd\u54c1\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u306e\u304a\u77e5\u3089\u305b\uff08\u767b\u9332\u30e6\u30fc\u30b6\u30fc\u306e\u307f\u3001\u914d\u4fe1\u505c\u6b62\u53ef\uff09</li> <li>\u30b5\u30dd\u30fc\u30c8\u5bfe\u5fdc</li> <li>\u6cd5\u4ee4\u4e0a\u306e\u7fa9\u52d9\u5c65\u884c\uff08\u7a0e\u52d9\u30fb\u4f1a\u8a08\u51e6\u7406\uff09</li> </ul>"},{"location":"legal/privacy/#3","title":"3. \u7b2c\u4e09\u8005\u3078\u306e\u60c5\u5831\u63d0\u4f9b","text":"<p>\u5f53\u793e\u306f\u3001\u6c7a\u6e08\u51e6\u7406\u30fb\u30e9\u30a4\u30bb\u30f3\u30b9\u7ba1\u7406\u306e\u305f\u3081\u306b LemonSqueezy \u3068\u5fc5\u8981\u306a\u60c5\u5831\u3092\u5171\u6709\u3059\u308b\u5834\u5408\u3001\u304a\u3088\u3073\u6cd5\u4ee4\u4e0a\u306e\u8981\u8acb\u304c\u3042\u308b\u5834\u5408\u3092\u9664\u304d\u3001\u500b\u4eba\u60c5\u5831\u3092\u7b2c\u4e09\u8005\u306b\u63d0\u4f9b\u3057\u307e\u305b\u3093\u3002\u30de\u30fc\u30b1\u30c6\u30a3\u30f3\u30b0\u76ee\u7684\u3067\u306e\u30c7\u30fc\u30bf\u8ca9\u58f2\u30fb\u5171\u6709\u306f\u884c\u3044\u307e\u305b\u3093\u3002</p>"},{"location":"legal/privacy/#4","title":"4. \u30c7\u30fc\u30bf\u306e\u4fdd\u5b58\u671f\u9593","text":"<ul> <li>\u8cfc\u5165\u60c5\u5831\u30fb\u30e9\u30a4\u30bb\u30f3\u30b9\u60c5\u5831: LemonSqueezy \u306e\u30c7\u30fc\u30bf\u4fdd\u6301\u30dd\u30ea\u30b7\u30fc\u306b\u6e96\u62e0</li> <li>\u30b5\u30dd\u30fc\u30c8\u30e1\u30fc\u30eb: \u5bfe\u5fdc\u5b8c\u4e86\u5f8c 2 \u5e74\u9593</li> <li>\u30ed\u30fc\u30ab\u30eb\u8a8d\u8a3c\u30ad\u30e3\u30c3\u30b7\u30e5: \u30e6\u30fc\u30b6\u30fc\u304c\u524a\u9664\u3059\u308b\u307e\u3067\u3001\u307e\u305f\u306f <code>forge license deactivate</code> \u5b9f\u884c\u307e\u3067\u4fdd\u6301</li> </ul>"},{"location":"legal/privacy/#5-cookie","title":"5. Cookie\u30fb\u30c8\u30e9\u30c3\u30ad\u30f3\u30b0","text":"<p>\u672c\u30a6\u30a7\u30d6\u30b5\u30a4\u30c8\u3067\u306f Google Analytics \u3092\u4f7f\u7528\u3057\u3066\u30a2\u30af\u30bb\u30b9\u72b6\u6cc1\u3092\u5206\u6790\u3057\u3066\u3044\u307e\u3059\u3002\u30d6\u30e9\u30a6\u30b6\u306e\u8a2d\u5b9a\u304b\u3089 Cookie \u3092\u7121\u52b9\u5316\u3059\u308b\u3053\u3068\u3067\u8a08\u6e2c\u3092\u62d2\u5426\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"legal/privacy/#6","title":"6. \u304a\u554f\u3044\u5408\u308f\u305b","text":"<p>\u500b\u4eba\u60c5\u5831\u306e\u53d6\u308a\u6271\u3044\u306b\u95a2\u3059\u308b\u304a\u554f\u3044\u5408\u308f\u305b\u30fb\u958b\u793a\u30fb\u524a\u9664\u8981\u6c42\u306f\u4ee5\u4e0b\u306b\u3054\u9023\u7d61\u304f\u3060\u3055\u3044\u3002</p> <p>Email: support@alforgelabs.com</p> <p>\u540c\u671f\u5143: <code>ja/privacy.html</code>\uff08\u6700\u7d42\u66f4\u65b0\u65e5: 2026 \u5e74 4 \u6708 25 \u65e5\uff09\u3002\u672c\u30da\u30fc\u30b8\u306e\u8a18\u8ff0\u3068\u516c\u5f0f <code>privacy.html</code> \u306e\u9593\u3067\u9f5f\u9f6c\u304c\u3042\u308b\u5834\u5408\u306f <code>privacy.html</code> \u304c\u512a\u5148\u3057\u307e\u3059\u3002</p>"}]}